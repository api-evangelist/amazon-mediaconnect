{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amazon-mediaconnect/refs/heads/main/json-structure/mediaconnect-api-listed-entitlement-structure.json",
  "name": "ListedEntitlement",
  "type": "object",
  "description": "An entitlement that has been granted to you from other AWS accounts.",
  "properties": {
    "DataTransferSubscriberFeePercent": {
      "allOf": [
        {
          "$ref": "#/components/schemas/__integer"
        },
        {
          "xml": {
            "name": "dataTransferSubscriberFeePercent"
          },
          "description": "Percentage from 0-100 of the data transfer cost to be billed to the subscriber."
        }
      ]
    },
    "EntitlementArn": {
      "allOf": [
        {
          "$ref": "#/components/schemas/__string"
        },
        {
          "xml": {
            "name": "entitlementArn"
          },
          "description": "The ARN of the entitlement."
        }
      ]
    },
    "EntitlementName": {
      "allOf": [
        {
          "$ref": "#/components/schemas/__string"
        },
        {
          "xml": {
            "name": "entitlementName"
          },
          "description": "The name of the entitlement."
        }
      ]
    }
  },
  "required": [
    "EntitlementArn",
    "EntitlementName"
  ]
}